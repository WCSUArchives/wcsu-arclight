<% manifest_url = @document['dado_identifier_ssm']&.first %>
<% action = @document['dado_action_ssm']&.first %>

<% if action&.downcase == "embed" && manifest_url.present? %>
  <%# Wrapper: Mirador and overlay are siblings. Mirador cannot destroy the overlay. %>
  <div class="mb-3" style="position: relative; height: 600px;">
    <div id="mirador-container" style="height: 100%;"></div>

    <div id="mirador-overlay" style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; display: flex; align-items: center; justify-content: center; background: #f8f9fa; z-index: 10;">
      <div id="mirador-overlay-content" style="text-align: center; color: #6c757d;">
        <div class="spinner-border mb-3" role="status" style="width: 3rem; height: 3rem; display: block; margin-left: auto; margin-right: auto;">
          <span class="visually-hidden">Loading...</span>
        </div>
        <div>Loading image viewer...</div>
      </div>
    </div>
  </div>

  <%= javascript_include_tag "https://unpkg.com/mirador@4/dist/mirador.min.js" %>


<script>
  (function() {
    const manifestUrl = '<%= manifest_url %>';
    const overlay     = document.getElementById('mirador-overlay');
    const content     = document.getElementById('mirador-overlay-content');

    // Prevent double-init if Turbo revisits this page
    if (document.getElementById('mirador-container').dataset.miradorReady === 'true') {
      if (overlay) overlay.style.display = 'none';
      return;
    }

    const initMirador = function() {
      if (typeof window.Mirador === 'undefined') {
        setTimeout(initMirador, 300);
        return;
      }

      Mirador.viewer({
        id: 'mirador-container',
        windows: [{
          loadedManifest: manifestUrl,
          canvasIndex: 0
        }]
      });
      document.getElementById('mirador-container').dataset.miradorReady = 'true';

      // Poll for the canvas to appear, then hide overlay
      let attempts = 0;
      const interval = setInterval(function() {
        attempts++;
        const hasCanvas = document.querySelector('#mirador-container canvas');
        if (hasCanvas && overlay) {
          overlay.style.display = 'none';
          clearInterval(interval);
        } else if (attempts > 30) { // 15 seconds
          clearInterval(interval);
          // Your "still loading?" message here...
        }
      }, 500);
    };

    // Turbo-safe: run now if DOM is already past loading
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initMirador);
    } else {
      initMirador();
    }
  })();
</script>


<% end %>

<% if action&.downcase == "embed" %>
  <div class="al-oembed-viewer mb-2">
    <div class="al-digital-object">
      <% display_url = @resource.href
           .gsub(%r{/iiif-p/manifest$}, '')
           .gsub('/omeka-s/iiif/3/', '/omeka-s/s/digital/item/')
           .gsub(%r{/manifests/(\d+)\.json$}, '/catalog/\1')  # <-- Yale: /manifests/ID.json → /catalog/ID
           .gsub('/manifest', '') %>
      <%= link_to @resource.label, display_url, class: 'btn btn-outline-primary btn-sm' %>
    </div>
  </div>
<% else %>
  <%= tag.div(class: 'al-oembed-viewer mb-2', data: { controller: 'arclight-oembed', arclight_oembed_url_value: @resource.href }) do %>
    <div class="al-digital-object">

	<% display_url = @resource.href
	     .gsub(%r{/iiif-p/manifest$}, '')
	     .gsub('/omeka-s/iiif/3/', '/omeka-s/s/digital/item/')
	     .gsub(%r{/manifests/(\d+)\.json$}, '/catalog/\1')  # <-- Yale: /manifests/ID.json → /catalog/ID
	     .gsub('/manifest', '') %>

      <%= link_to @resource.label, display_url, class: 'btn btn-outline-primary btn-sm' %>
    </div>
  <% end %>
<% end %>
